{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "Backend/**"
    }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/favicon.(ico|svg|png)",
      "dest": "/favicon.$1"
    },
    {
      "src": "/logo.svg",
      "dest": "/logo.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
